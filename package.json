{
  "name": "llm-score-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "validate": "node scripts/validate.js",
    "pack": "node scripts/pack.js",
    "upload": "chrome-webstore-upload upload --source ./llm-score.zip"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.182",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "archiver": "^6.0.0",
    "chrome-webstore-upload": "^4.0.1",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.3"
  }
}
